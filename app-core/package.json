{
  "name": "app-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "npm run build && electron-builder",
    "lint": "oxlint src electron",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.vtuber.livestudio",
    "productName": "VTuber Live Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "public"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.svg"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@pixiv/three-vrm": "^3.5.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "lucide-react": "^1.21.0",
    "node-key-sender": "^1.0.11",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "spotify-web-api-node": "^5.0.2",
    "three": "^0.184.0",
    "tiktok-live-connector": "^2.4.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-store": "^11.0.2",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}
